# DecisionFlow local environment settings
# Do not commit this file. It contains tenant-specific values.
# Copy this file to .env and fill in your values.

# === Required: Power Apps session details ===
# How to get: Power Apps portal (make.powerapps.com) > 右上の ⚙ > セッション詳細 > コピー
# DATAVERSE_URL  = "Instance URL" の値
# TENANT_ID      = "Tenant ID" の値
# ENVIRONMENT_ID = "Environment ID" の値（pac auth create --environment の引数にも使用）
DATAVERSE_URL=https://{your-org}.crm7.dynamics.com/
TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ENVIRONMENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# 言語コード: 1041=日本語, 1033=英語。環境の言語に合わせて設定する
DATAVERSE_LANGUAGE_CODE=1041

# === Optional reference values from session details ===
# セッション詳細の "Organization ID" / "Unique name" の値（スクリプトが自動取得するため通常は不要）
ORGANIZATION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ORGANIZATION_UNIQUE_NAME=unq{hex}

# === Solution ===
# 変更不要。別テナントへ移植する場合のみ修正する
SOLUTION_NAME=DecisionSupport
PUBLISHER_PREFIX=ds

# === Code Apps ===
# How to get: pac auth list で表示されるプロファイル名
# 例: pac auth create --name DecisionSupportProfile --environment {ENVIRONMENT_ID}
PAC_AUTH_PROFILE=DecisionSupportProfile

# === Copilot Studio ===
# BOT_ID: Copilot Studio UI でエージェント作成後、URL の botId パラメータから取得
#   例: https://copilotstudio.microsoft.com/...?botId=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
BOT_ID=
# 通知メールのリンクは .env ではなく、ソリューション環境変数で設定する:
#   ds_DecisionFlowAppBaseUrl = Code Apps の公開 URL ベース
#   ds_CopilotTeamsAppId = Teams manifest の botChannelRegistrationAppId

# === Publisher / Solution display names (optional) ===
# こだわりがなければ変更不要
PUBLISHER_UNIQUE_NAME=ds_publisher
PUBLISHER_DISPLAY_NAME=DecisionFlow Publisher
SOLUTION_DISPLAY_NAME=意思決定支援 (Decision Support)
